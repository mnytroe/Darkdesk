{
  "manifest_version": 3,
  "name": "DarkDesk – Dark Mode for Freshdesk",
  "version": "1.0.2",
  "description": "Enables dark mode on Freshdesk agent panels.",
  "permissions": ["storage", "activeTab"],
  "content_scripts": [
    {
      "matches": ["*://*.freshdesk.com/*"],
      "css": ["dark-mode.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["dark-mode.css"],
      "matches": ["*://*.freshdesk.com/*"]
    }
  ]
}
